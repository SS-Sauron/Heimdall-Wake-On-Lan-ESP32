<div class="flex justify-center mb-4 relative">
<div aria-hidden="true" class="absolute inset-0 flex items-center justify-center opacity-10 morse-eye select-none pointer-events-none text-[8px] tracking-widest text-oracle-gold font-label-caps">
                    -.. --- / -. --- - / .-.. --- --- -.- / .- - / -- .
                </div>
<span class="material-symbols-outlined text-[64px] text-oracle-gold opacity-50" style="font-variation-settings: &quot;FILL&quot; 0; stroke-width: 1.5px;">visibility</span>
</div>
